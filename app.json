{
  "expo": {
    "name": "Yuva",
    "slug": "yuva-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "yuva",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aidgroup.yuva"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#8B3FD6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.aidgroup.yuva"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-localization",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Yuva to access your photos to add them to your listing."
        }
      ]
    ]
  }
}
